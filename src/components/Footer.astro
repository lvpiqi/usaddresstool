---
import { countries } from "../data/countries";
import {
  getBlogIndexPath,
  getCountriesPath,
  getCountryPath,
  getFormatIndexPath,
  getHomePath,
  getInfoPath,
  getTaxFreePath,
  localeMeta,
  locales,
  siteConfig,
  type Locale
} from "../data/site";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const currentYear = new Date().getFullYear();

const featuredCountrySlugs = ["us", "jp", "ca", "hk", "uk", "in"];
const featuredCountries = featuredCountrySlugs
  .map((slug) => countries.find((country) => country.slug === slug))
  .filter(Boolean);
const contactEmail = "km3266899@gmail.com";
const contactTelegramUrl = "https://t.me/ssq789";
const contactTelegramHandle = "@ssq789";

const footerText = {
  zh: {
    intro:
      "真实有效美国地址生成器，秒级生成含ZIP邮编的有效地址。支持软件测试、数据库填充与表单验证场景，免费使用。",
    compliance: "",
    dataNote: "",
    languages: "站点语言",
    popular: "热门地址页",
    resources: "资源中心",
    legal: "法律与政策",
    countryDirectory: "国家目录",
    formats: "地址格式",
    blog: "博客",
    about: "关于本站",
    privacy: "隐私政策",
    terms: "使用条款",
    cookies: "Cookie 政策",
    taxFree: "美国免税州",
    rights: "保留所有权利。"
  },
  en: {
    intro:
      "A multilingual real-format address tool for testing, form validation, demos, and address-format research.",
    compliance:
      "This site is for QA, education, demos, and address-format research only, not impersonation, fraud, or platform circumvention.",
    dataNote: "For production workflows, plug in your own validation, risk, and compliance controls.",
    languages: "Languages",
    popular: "Popular generators",
    resources: "Resources",
    legal: "Legal",
    countryDirectory: "Country directory",
    formats: "Address formats",
    blog: "Blog",
    about: "About",
    privacy: "Privacy Policy",
    terms: "Terms of Use",
    cookies: "Cookie Policy",
    taxFree: "US tax-free addresses",
    rights: "All rights reserved."
  },
  ja: {
    intro:
      "テスト、フォーム検証、デモ、住所形式の調査向けに作られた多言語の実在形式住所ツールです。",
    compliance:
      "本サイトは QA、教育、デモ、住所形式研究のためのものであり、なりすまし、詐欺、規約回避には利用できません。",
    dataNote: "本番業務では、独自の住所検証、リスク管理、コンプライアンス工程を組み込んでください。",
    languages: "言語",
    popular: "人気の住所ページ",
    resources: "リソース",
    legal: "法務とポリシー",
    countryDirectory: "国別一覧",
    formats: "住所形式",
    blog: "ブログ",
    about: "このサイトについて",
    privacy: "プライバシーポリシー",
    terms: "利用規約",
    cookies: "Cookie ポリシー",
    taxFree: "米国免税州住所",
    rights: "All rights reserved."
  }
}[locale];
---

<footer class="site-footer">
  <div class="container">
    <div class="site-footer__grid">
      <section class="site-footer__intro">
        <p class="site-footer__brand">{siteConfig.name}</p>
        {footerText.intro ? <p>{footerText.intro}</p> : null}
        {footerText.compliance ? <p>{footerText.compliance}</p> : null}
        {footerText.dataNote ? <p>{footerText.dataNote}</p> : null}

        <section class="site-footer__contact" aria-label="Contact links">
          <div class="site-footer__contact-list">
              <a
                aria-label={`Email: ${contactEmail}`}
                class="footer-contact-link"
                href={`mailto:${contactEmail}`}
                title={contactEmail}
              >
                <span class="footer-contact-link__icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24">
                    <path
                      d="M4 7.5A2.5 2.5 0 0 1 6.5 5h11A2.5 2.5 0 0 1 20 7.5v9a2.5 2.5 0 0 1-2.5 2.5h-11A2.5 2.5 0 0 1 4 16.5v-9Z"
                      fill="none"
                      stroke="currentColor"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="1.8"
                    ></path>
                    <path
                      d="m5 8 7 5 7-5"
                      fill="none"
                      stroke="currentColor"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="1.8"
                    ></path>
                  </svg>
                </span>
              </a>
              <a
                aria-label={`Telegram: ${contactTelegramHandle}`}
                class="footer-contact-link"
                href={contactTelegramUrl}
                rel="me noopener noreferrer"
                target="_blank"
                title={contactTelegramHandle}
              >
                <span class="footer-contact-link__icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24">
                    <path
                      d="M21 4 3.8 10.8c-.8.3-.8 1.4 0 1.7l4.4 1.5 1.6 4.8c.3.8 1.3.9 1.8.2L14 15l4.5 3.5c.7.5 1.7.1 1.9-.8L22 5.5A1.2 1.2 0 0 0 21 4Z"
                      fill="none"
                      stroke="currentColor"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="1.8"
                    ></path>
                    <path
                      d="M8.2 14 18.5 7.4"
                      fill="none"
                      stroke="currentColor"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="1.8"
                    ></path>
                  </svg>
                </span>
              </a>
          </div>
        </section>

        <div class="site-footer__languages">
          <h2>{footerText.languages}</h2>
          <div class="site-footer__language-list">
            {locales.map((code) => (
              <a href={getHomePath(code)} lang={localeMeta[code].htmlLang}>
                {localeMeta[code].label}
              </a>
            ))}
          </div>
        </div>
      </section>

      <nav class="site-footer__section" aria-label={footerText.popular}>
        <h2>{footerText.popular}</h2>
        <ul class="footer-list">
          <li><a href={getTaxFreePath(locale)}>{footerText.taxFree}</a></li>
          {featuredCountries.map((country) =>
            country ? (
              <li>
                <a href={getCountryPath(locale, country.slug)}>{country.heading[locale]}</a>
              </li>
            ) : null
          )}
        </ul>
      </nav>

      <nav class="site-footer__section" aria-label={footerText.resources}>
        <h2>{footerText.resources}</h2>
        <ul class="footer-list">
          <li><a href={getCountriesPath(locale)}>{footerText.countryDirectory}</a></li>
          <li><a href={getFormatIndexPath(locale)}>{footerText.formats}</a></li>
          <li><a href={getBlogIndexPath(locale)}>{footerText.blog}</a></li>
          <li><a href={getInfoPath(locale, "about")}>{footerText.about}</a></li>
        </ul>
      </nav>

      <nav class="site-footer__section" aria-label={footerText.legal}>
        <h2>{footerText.legal}</h2>
        <ul class="footer-list">
          <li><a href={getInfoPath(locale, "privacy")}>{footerText.privacy}</a></li>
          <li><a href={getInfoPath(locale, "terms")}>{footerText.terms}</a></li>
          <li><a href={getInfoPath(locale, "cookies")}>{footerText.cookies}</a></li>
        </ul>
      </nav>
    </div>

    <div class="site-footer__bottom">
      <p>
        © {currentYear} {siteConfig.name}. {footerText.rights}
      </p>
    </div>
  </div>
</footer>
