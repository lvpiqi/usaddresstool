---
import Footer from "./Footer.astro";
import Header from "./Header.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCountryBySlug } from "../data/countries";
import { withCountryContent } from "../data/country-content";
import {
  alternateLocaleLinks,
  getCountryPath,
  getFormatPath,
  getHomePath,
  locales,
  ui,
  type Locale
} from "../data/site";
import { toAbsoluteUrl } from "../utils/seo";

interface Props {
  locale: Locale;
  countrySlug: string;
}

const { locale, countrySlug } = Astro.props;
const country = getCountryBySlug(countrySlug);

if (!country) {
  throw new Error(`Unknown country slug: ${countrySlug}`);
}

const pageCountry = withCountryContent(country);

const canonicalPath = getFormatPath(locale, country.slug);
const alternatePaths = Object.fromEntries(
  locales.map((lang) => [lang, getFormatPath(lang, country.slug)])
) as Record<Locale, string>;
const strings = ui[locale];
const formatTitle = {
  zh: `${pageCountry.name[locale]}地址格式`,
  en: `${pageCountry.name[locale]} Address Format`,
  ja: `${pageCountry.name[locale]}の住所形式`
}[locale];
const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    name: formatTitle,
    description: pageCountry.metaDescription[locale],
    url: toAbsoluteUrl(canonicalPath, Astro.site)
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: strings.common.breadcrumbsHome,
        item: toAbsoluteUrl(getHomePath(locale), Astro.site)
      },
      {
        "@type": "ListItem",
        position: 2,
        name: formatTitle,
        item: toAbsoluteUrl(canonicalPath, Astro.site)
      }
    ]
  }
];
---

<BaseLayout
  locale={locale}
  title={formatTitle}
  description={pageCountry.metaDescription[locale]}
  canonicalPath={canonicalPath}
  alternates={alternateLocaleLinks(alternatePaths)}
  schema={schema}
>
  <Header
    locale={locale}
    alternatePaths={alternatePaths}
    currentCountrySlug={country.slug}
  />

  <main>
    <section class="hero hero--simple">
      <div class="container">
        <p class="eyebrow">{strings.nav.formats}</p>
        <h1>{formatTitle}</h1>
        <p class="hero__copy">{pageCountry.toolSummary[locale]}</p>
      </div>
    </section>

    <section class="section">
      <div class="container content-grid">
        <article class="content-card">
          <h2>{strings.sections.formatGuide}</h2>
          <ul class="detail-list">
            {pageCountry.formatRules[locale].map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </article>

        <article class="content-card">
          <h2>{strings.sections.regionGuide}</h2>
          <ul class="detail-list">
            {pageCountry.regionNotes[locale].map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </article>
      </div>
    </section>

    <section class="section">
      <div class="container content-grid">
        <article class="content-card">
          <h2>{strings.sections.sampleAddress}</h2>
          <div class="address-sample">
            {pageCountry.sampleAddress[locale].map((line) => (
              <span>{line}</span>
            ))}
          </div>
        </article>

        <article class="content-card">
          <h2>{strings.sections.useCases}</h2>
          <ul class="detail-list">
            {pageCountry.useCases[locale].map((item) => (
              <li>{item}</li>
            ))}
          </ul>
          <a class="text-link" href={getCountryPath(locale, country.slug)}>
            {strings.common.readMore}
          </a>
        </article>
      </div>
    </section>
  </main>

  <Footer locale={locale} />
</BaseLayout>
