---
import Footer from "./Footer.astro";
import Header from "./Header.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getBlogPost } from "../data/blog";
import { getCountryBySlug } from "../data/countries";
import { withCountryContent } from "../data/country-content";
import {
  alternateLocaleLinks,
  getBlogPath,
  getCountryPath,
  getFormatIndexPath,
  getFormatPath,
  getHomePath,
  locales,
  ui,
  type Locale
} from "../data/site";
import {
  getCountryFormatSeo,
  getCountryVisibleFaq
} from "../utils/country-page-seo";
import { getFormatKeywords } from "../utils/keywords";
import { toAbsoluteUrl } from "../utils/seo";

interface Props {
  locale: Locale;
  countrySlug: string;
}

const { locale, countrySlug } = Astro.props;
const country = getCountryBySlug(countrySlug);

if (!country) {
  throw new Error(`Unknown country slug: ${countrySlug}`);
}

const pageCountry = withCountryContent(country);
const canonicalPath = getFormatPath(locale, country.slug);
const alternatePaths = Object.fromEntries(
  locales.map((lang) => [lang, getFormatPath(lang, country.slug)])
) as Record<Locale, string>;
const strings = ui[locale];
const relatedPosts = pageCountry.relatedPosts
  .map((slug) => getBlogPost(slug))
  .filter(Boolean);
const formatSeo = getCountryFormatSeo(locale, pageCountry);
const formatTitle = formatSeo.title;
const formatMetaDescription = formatSeo.description;
const pageFaq = getCountryVisibleFaq(locale, pageCountry);

const formatCopy = {
  zh: {
    overviewEyebrow: "格式说明",
    overviewTitle: `如何理解${pageCountry.name.zh}地址格式`,
    overviewParagraphs: [
      `${pageCountry.name.zh}地址格式页的重点不是重复生成按钮，而是把地址顺序、${pageCountry.regionLabel.zh}字段和邮编规则解释清楚，让用户知道为什么结果会这样排列。`,
      "如果你在做注册页、结账页、数据库样例或地址字段研究，先看格式页理解结构，再回到生成页做实际测试，会更高效。"
    ],
    checklistEyebrow: "填写提示",
    checklistTitle: "浏览格式页时建议先看这些内容",
    checklist: [
      `先确认目标表单里的${pageCountry.regionLabel.zh}字段是要求全称还是缩写。`,
      "再确认邮编字段是否需要单独输入，以及是否有固定字符长度或格式限制。",
      "复制完整地址之前，检查街道、城市、地区和邮编的顺序是否符合该国家的习惯。"
    ],
    faqTitle: `${pageCountry.name.zh}地址格式 FAQ`,
    relatedTitle: `${pageCountry.name.zh}相关页面`,
    relatedDescription:
      "继续进入生成器、相关文章或地址格式目录，让国家页、格式页和博客页形成清晰的站内主题链路。",
    generatorCardTitle: `${pageCountry.name.zh}地址生成器`,
    generatorCardDescription: "返回工具页，按地区筛选并生成可复制的结构化地址结果。",
    directoryCardTitle: "地址格式目录",
    directoryCardDescription: "继续对比其他国家的地址顺序、邮编规则和字段写法。"
  },
  en: {
    overviewEyebrow: "Format overview",
    overviewTitle: `How To Read the ${pageCountry.name.en} Address Format`,
    overviewParagraphs: [
      `This page explains address order, ${pageCountry.regionLabel.en.toLowerCase()} fields, and postal-code behavior so the generator output feels understandable instead of random.`,
      "If you are working on sign-up forms, checkout flows, sample data, or address-field research, it is usually better to learn the structure here first and then return to the generator."
    ],
    checklistEyebrow: "Form tips",
    checklistTitle: "What To Check On This Format Page",
    checklist: [
      `Confirm whether your target form expects a full ${pageCountry.regionLabel.en.toLowerCase()} name or an abbreviation.`,
      "Check whether postal code should be entered as its own field and whether strict length or pattern rules apply.",
      "Make sure the order of street, city, region, and postal code matches the local convention before copying the full address."
    ],
    faqTitle: `${pageCountry.name.en} Address Format FAQ`,
    relatedTitle: `Related ${pageCountry.name.en} Pages`,
    relatedDescription:
      "Use this guide as the format layer between the generator, the country page, and supporting blog posts.",
    generatorCardTitle: `${pageCountry.name.en} Address Generator`,
    generatorCardDescription:
      "Return to the tool page and generate structured, copy-ready address results.",
    directoryCardTitle: "Address format directory",
    directoryCardDescription:
      "Compare address order, postal rules, and field naming across other countries."
  },
  ja: {
    overviewEyebrow: "形式ガイド",
    overviewTitle: `${pageCountry.name.ja}の住所形式を理解するポイント`,
    overviewParagraphs: [
      `このページは、住所順序、${pageCountry.regionLabel.ja}項目、郵便番号ルールを整理し、生成結果の意味を理解しやすくするための形式ガイドです。`,
      "登録フォーム、チェックアウト、サンプルデータ、住所研究に使う前に、まずここで形式を確認してから生成ページへ戻る流れが自然です。"
    ],
    checklistEyebrow: "入力チェック",
    checklistTitle: "形式ページで先に確認したい点",
    checklist: [
      `${pageCountry.regionLabel.ja}項目が正式名称なのか略称なのかを確認します。`,
      "郵便番号が独立項目かどうか、文字数や入力ルールがあるかを確認します。",
      "完全な住所をコピーする前に、street、city、region、postal code の並びがその国の慣習に合っているかを見ます。"
    ],
    faqTitle: `${pageCountry.name.ja}の住所形式 FAQ`,
    relatedTitle: `${pageCountry.name.ja}関連ページ`,
    relatedDescription:
      "生成ページ、関連記事、住所形式ディレクトリへ自然につながるよう、内部リンクをまとめています。",
    generatorCardTitle: `${pageCountry.name.ja}住所ジェネレーター`,
    generatorCardDescription:
      "ツールページへ戻り、地域で絞り込んだ住所結果を生成できます。",
    directoryCardTitle: "住所形式ディレクトリ",
    directoryCardDescription:
      "他国の住所順序、郵便番号ルール、項目名も比較できます。"
  }
}[locale];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    name: formatTitle,
    description: formatMetaDescription,
    url: toAbsoluteUrl(canonicalPath, Astro.site),
    inLanguage: locale,
    about: {
      "@type": "Place",
      name: pageCountry.name[locale]
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: strings.common.breadcrumbsHome,
        item: toAbsoluteUrl(getHomePath(locale), Astro.site)
      },
      {
        "@type": "ListItem",
        position: 2,
        name: strings.nav.formats,
        item: toAbsoluteUrl(getFormatIndexPath(locale), Astro.site)
      },
      {
        "@type": "ListItem",
        position: 3,
        name: formatTitle,
        item: toAbsoluteUrl(canonicalPath, Astro.site)
      }
    ]
  }
];
---

<BaseLayout
  locale={locale}
  title={formatTitle}
  description={formatMetaDescription}
  canonicalPath={canonicalPath}
  keywords={getFormatKeywords(locale, pageCountry)}
  alternates={alternateLocaleLinks(alternatePaths)}
  schema={schema}
>
  <Header
    locale={locale}
    alternatePaths={alternatePaths}
    currentCountrySlug={country.slug}
  />

  <main>
    <section class="hero hero--simple">
      <div class="container">
        <p class="eyebrow">{strings.nav.formats}</p>
        <h1>{formatTitle}</h1>
        <p class="hero__copy">{formatMetaDescription}</p>
      </div>
    </section>

    <section class="section section--compact">
      <div class="container content-grid">
        <article class="content-card">
          <p class="eyebrow">{formatCopy.overviewEyebrow}</p>
          <h2>{formatCopy.overviewTitle}</h2>
          {formatCopy.overviewParagraphs.map((paragraph) => (
            <p>{paragraph}</p>
          ))}
        </article>

        <article class="content-card">
          <p class="eyebrow">{formatCopy.checklistEyebrow}</p>
          <h2>{formatCopy.checklistTitle}</h2>
          <ul class="detail-list">
            {formatCopy.checklist.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
          <a class="text-link" href={getCountryPath(locale, country.slug)}>
            {strings.common.readMore}
          </a>
        </article>
      </div>
    </section>

    <section class="section">
      <div class="container content-grid">
        <article class="content-card">
          <h2>{strings.sections.formatGuide}</h2>
          <ul class="detail-list">
            {pageCountry.formatRules[locale].map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </article>

        <article class="content-card">
          <h2>{strings.sections.regionGuide}</h2>
          <ul class="detail-list">
            {pageCountry.regionNotes[locale].map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </article>
      </div>
    </section>

    <section class="section">
      <div class="container content-grid">
        <article class="content-card">
          <h2>{strings.sections.sampleAddress}</h2>
          <div class="address-sample">
            {pageCountry.sampleAddress[locale].map((line) => (
              <span>{line}</span>
            ))}
          </div>
        </article>

        <article class="content-card">
          <h2>{strings.sections.useCases}</h2>
          <ul class="detail-list">
            {pageCountry.useCases[locale].map((item) => (
              <li>{item}</li>
            ))}
          </ul>
          <a class="text-link" href={getCountryPath(locale, country.slug)}>
            {strings.common.readMore}
          </a>
        </article>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="section-heading">
          <p class="eyebrow">{strings.sections.faq}</p>
          <h2>{formatCopy.faqTitle}</h2>
        </div>
        <div class="faq-list">
          {pageFaq.map((item) => (
            <details class="faq-item">
              <summary>{item.question}</summary>
              <p>{item.answer}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <section class="section section--compact">
      <div class="container">
        <div class="section-heading">
          <p class="eyebrow">{strings.common.relatedPosts}</p>
          <h2>{formatCopy.relatedTitle}</h2>
          <p>{formatCopy.relatedDescription}</p>
        </div>
        <div class="card-grid">
          <article class="link-card">
            <h3>{formatCopy.generatorCardTitle}</h3>
            <p>{formatCopy.generatorCardDescription}</p>
            <a class="text-link" href={getCountryPath(locale, country.slug)}>
              {strings.common.readMore}
            </a>
          </article>

          {relatedPosts.map((post) =>
            post ? (
              <article class="link-card">
                <h3>{post.title[locale]}</h3>
                <p>{post.description[locale]}</p>
                <a class="text-link" href={getBlogPath(locale, post.slug)}>
                  {strings.common.readMore}
                </a>
              </article>
            ) : null
          )}

          <article class="link-card">
            <h3>{formatCopy.directoryCardTitle}</h3>
            <p>{formatCopy.directoryCardDescription}</p>
            <a class="text-link" href={getFormatIndexPath(locale)}>
              {strings.common.readMore}
            </a>
          </article>
        </div>
      </div>
    </section>
  </main>

  <Footer locale={locale} />
</BaseLayout>
