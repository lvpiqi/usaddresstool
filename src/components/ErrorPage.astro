---
import BaseLayout from "../layouts/BaseLayout.astro";
import Footer from "./Footer.astro";
import { getCountryBySlug } from "../data/countries";
import {
  getBlogIndexPath,
  getCountriesPath,
  getCountryPath,
  getHomePath,
  getTaxFreePath,
  localeMeta,
  locales,
  siteConfig,
  ui,
  type Locale
} from "../data/site";

interface Props {
  locale: Locale;
  statusCode: 403 | 404 | 500 | 503;
}

const { locale, statusCode } = Astro.props;
const strings = ui[locale];

const getStatusPath = (lang: Locale, code: 403 | 404 | 500 | 503) =>
  lang === "zh" ? `/${code}/` : `/${lang}/${code}/`;

const statusCopy = {
  403: {
    title: {
      zh: "页面暂不可用",
      en: "This Page Is Not Available",
      ja: "このページは現在利用できません"
    },
    description: {
      zh: "当前请求无法访问这个页面，可能是访问规则、部署配置或临时限制导致的。",
      en: "The current request cannot access this page because of an access rule, deployment setting, or temporary restriction.",
      ja: "アクセスルール、デプロイ設定、または一時的な制限により、このページへアクセスできません。"
    },
    note: {
      zh: "如果这是意外结果，建议先检查访问控制、Cloudflare 配置和 Worker 路由。",
      en: "If this is unexpected, review your access controls, Cloudflare settings, and Worker routes first.",
      ja: "想定外であれば、アクセス制御、Cloudflare 設定、Worker ルートを先に確認してください。"
    }
  },
  404: {
    title: {
      zh: "页面不存在",
      en: "Page Not Found",
      ja: "ページが見つかりません"
    },
    description: {
      zh: "这个链接可能已经变更、删除，或者输入的 URL 不正确。",
      en: "The link may have changed, been removed, or the URL may be incorrect.",
      ja: "リンクが変更・削除されたか、URL が正しくない可能性があります。"
    },
    note: {
      zh: "如果这是站内链接跳转过来的，建议顺手修复对应的失效入口。",
      en: "If this came from an internal link, it is worth fixing the broken entry point in the site structure.",
      ja: "サイト内リンクから来た場合は、壊れている導線を修正するのが安全です。"
    }
  },
  500: {
    title: {
      zh: "服务器临时错误",
      en: "Temporary Server Error",
      ja: "一時的なサーバーエラー"
    },
    description: {
      zh: "请求已经到达站点，但页面暂时没有成功渲染。",
      en: "The request reached the site, but the page could not be rendered successfully right now.",
      ja: "リクエストは到達しましたが、ページを正常に描画できませんでした。"
    },
    note: {
      zh: "可以先回到稳定的工具页，或稍后刷新重试。",
      en: "You can return to a stable tool page first or reload later and try again.",
      ja: "いったん安定しているツールページへ戻るか、少し待って再読み込みしてください。"
    }
  },
  503: {
    title: {
      zh: "服务暂时不可用",
      en: "Service Temporarily Unavailable",
      ja: "サービスは一時的に利用できません"
    },
    description: {
      zh: "站点可能正在维护、预热，或等待上游依赖恢复。",
      en: "The site may be under maintenance, warming up, or waiting on an upstream dependency.",
      ja: "メンテナンス中、ウォームアップ中、または上流依存の復旧待ちの可能性があります。"
    },
    note: {
      zh: "这种状态通常是暂时的，稍等片刻后重试往往就会恢复。",
      en: "This state is often temporary, so a short wait and retry is usually enough.",
      ja: "この状態は一時的なことが多く、少し待ってから再試行すると戻る場合があります。"
    }
  }
}[statusCode];

const actionCopy = {
  zh: {
    eyebrow: "快速返回",
    title: "这些页面可以继续访问",
    description: "先回到稳定的工具页、目录页或内容页，通常能继续完成浏览或测试。",
    primary: "返回首页",
    secondary: "国家目录",
    retry: "刷新页面"
  },
  en: {
    eyebrow: "Quick paths",
    title: "Good places to continue",
    description: "Start from a stable tool page, directory, or content page and continue from there.",
    primary: "Back to home",
    secondary: "Country directory",
    retry: "Reload page"
  },
  ja: {
    eyebrow: "クイックパス",
    title: "続けやすいページ",
    description: "安定しているツールページ、一覧ページ、記事ページへ戻ると、そのまま閲覧を続けやすくなります。",
    primary: "ホームへ戻る",
    secondary: "国別ディレクトリ",
    retry: "再読み込み"
  }
}[locale];

const usCountry = getCountryBySlug("us");
const jpCountry = getCountryBySlug("jp");

if (!usCountry || !jpCountry) {
  throw new Error("Required country records for error pages are missing");
}

const quickLinks = [
  {
    title: usCountry.heading[locale],
    description: {
      zh: "回到美国首页工具，继续按州生成地址结果。",
      en: "Return to the US home page and keep generating state-based results.",
      ja: "US ホームページに戻って州別結果の生成を続けられます。"
    }[locale],
    href: getHomePath(locale)
  },
  {
    title: {
      zh: "美国免税州",
      en: "US tax-free page",
      ja: "US 免税州ページ"
    }[locale],
    description: {
      zh: "进入 5 个免税州工具页继续测试结账场景。",
      en: "Open the 5-state tax-free page for checkout and pricing scenarios.",
      ja: "5 つの免税州ページでチェックアウト系の確認を続けられます。"
    }[locale],
    href: getTaxFreePath(locale)
  },
  {
    title: jpCountry.heading[locale],
    description: {
      zh: "切换到日本页，继续查看多语言地址顺序。",
      en: "Jump to the Japan page and keep exploring multilingual address order.",
      ja: "日本ページへ移動して多言語の住所順序を確認できます。"
    }[locale],
    href: getCountryPath(locale, "jp")
  },
  {
    title: {
      zh: "博客",
      en: "Blog",
      ja: "ブログ"
    }[locale],
    description: {
      zh: "如果你只是想继续阅读说明内容，可以先回到博客目录。",
      en: "If you mainly want explanatory content, the blog index is a safe place to continue.",
      ja: "説明記事を読み進めたい場合は、ブログ一覧へ戻るのが安全です。"
    }[locale],
    href: getBlogIndexPath(locale)
  }
];
---

<BaseLayout
  locale={locale}
  title={`${statusCode} ${statusCopy.title[locale]}`}
  description={statusCopy.description[locale]}
  canonicalPath={getStatusPath(locale, statusCode)}
  alternates={locales.map((lang) => ({
    hreflang: localeMeta[lang].htmlLang,
    href: getStatusPath(lang, statusCode)
  }))}
  noindex={true}
>
  <header class="status-topbar">
    <div class="container status-topbar__inner">
      <a class="site-logo" href={getHomePath(locale)}>
        <span class="site-logo__mark">US</span>
        <span class="site-logo__copy">
          <strong>{siteConfig.name}</strong>
          <small>{statusCode}</small>
        </span>
      </a>

      <div class="language-switch" aria-label="Error page language switcher">
        {locales.map((code) => (
          <a
            href={getStatusPath(code, statusCode)}
            class:list={{
              "language-switch__link": true,
              "language-switch__link--active": code === locale
            }}
            lang={localeMeta[code].htmlLang}
          >
            {localeMeta[code].label}
          </a>
        ))}
      </div>
    </div>
  </header>

  <main class="status-page">
    <section class="hero hero--simple">
      <div class="container status-shell">
        <section class="status-card">
          <p class="eyebrow">HTTP {statusCode}</p>
          <p class="status-code" aria-hidden="true">{statusCode}</p>
          <h1>{statusCopy.title[locale]}</h1>
          <p class="hero__copy">{statusCopy.description[locale]}</p>
          <p class="status-note">{statusCopy.note[locale]}</p>

          <div class="status-actions">
            <a class="button button--primary" href={getHomePath(locale)}>
              {actionCopy.primary}
            </a>
            <a class="button button--ghost" href={getCountriesPath(locale)}>
              {actionCopy.secondary}
            </a>
            {statusCode >= 500 ? (
              <button class="button button--ghost" data-reload-page type="button">
                {actionCopy.retry}
              </button>
            ) : null}
          </div>
        </section>

        <section class="status-links">
          <div class="section-heading">
            <p class="eyebrow">{actionCopy.eyebrow}</p>
            <h2>{actionCopy.title}</h2>
            <p>{actionCopy.description}</p>
          </div>

          <div class="card-grid">
            {quickLinks.map((link) => (
              <article class="link-card">
                <h3>{link.title}</h3>
                <p>{link.description}</p>
                <a class="text-link" href={link.href}>
                  {strings.common.readMore}
                </a>
              </article>
            ))}
          </div>
        </section>
      </div>
    </section>
  </main>

  <Footer locale={locale} />
  <script is:inline>
    document.querySelectorAll("[data-reload-page]").forEach((node) => {
      if (!(node instanceof HTMLButtonElement)) {
        return;
      }

      node.addEventListener("click", () => {
        window.location.reload();
      });
    });
  </script>
</BaseLayout>
