---
import Footer from "./Footer.astro";
import Header from "./Header.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getBlogPost } from "../data/blog";
import { siteConfig } from "../data/site";
import {
  alternateLocaleLinks,
  getHomePath,
  getBlogIndexPath,
  getBlogPath,
  locales,
  ui,
  type Locale
} from "../data/site";
import { getBlogKeywords } from "../utils/keywords";
import { toAbsoluteUrl } from "../utils/seo";

interface Props {
  locale: Locale;
  slug: string;
}

const { locale, slug } = Astro.props;
const post = getBlogPost(slug);

if (!post) {
  throw new Error(`Unknown blog slug: ${slug}`);
}

const canonicalPath = getBlogPath(locale, slug);
const canonicalUrl = toAbsoluteUrl(canonicalPath, Astro.site);
const alternatePaths = Object.fromEntries(
  locales.map((lang) => [lang, getBlogPath(lang, slug)])
) as Record<Locale, string>;
const strings = ui[locale];
const relatedCopy = {
  zh: {
    title: "继续阅读",
    description: "从这篇文章继续进入工具页、格式页或相关主题文章。"
  },
  en: {
    title: "Continue reading",
    description: "Use these links to move into the related tool pages, format guides, and supporting articles."
  },
  ja: {
    title: "続きを読む",
    description: "このテーマに近いツールページ、形式ガイド、関連記事へ進めます。"
  }
}[locale];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    headline: post.title[locale],
    description: post.description[locale],
    datePublished: post.publishedAt,
    inLanguage: locale,
    mainEntityOfPage: canonicalUrl,
    url: canonicalUrl,
    author: {
      "@type": "Organization",
      name: siteConfig.name,
      url: toAbsoluteUrl(getHomePath(locale), Astro.site)
    },
    publisher: {
      "@type": "Organization",
      name: siteConfig.name,
      url: toAbsoluteUrl(getHomePath(locale), Astro.site)
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: strings.common.breadcrumbsHome,
        item: toAbsoluteUrl(getHomePath(locale), Astro.site)
      },
      {
        "@type": "ListItem",
        position: 2,
        name: strings.nav.blog,
        item: toAbsoluteUrl(getBlogIndexPath(locale), Astro.site)
      },
      {
        "@type": "ListItem",
        position: 3,
        name: post.title[locale],
        item: canonicalUrl
      }
    ]
  }
];
---

<BaseLayout
  locale={locale}
  title={post.title[locale]}
  description={post.description[locale]}
  canonicalPath={canonicalPath}
  keywords={getBlogKeywords(locale, post)}
  alternates={alternateLocaleLinks(alternatePaths)}
  schema={schema}
  ogType="article"
  publishedTime={post.publishedAt}
>
  <Header locale={locale} alternatePaths={alternatePaths} />

  <main>
    <article class="article-page">
      <div class="container article-page__inner">
        <p class="eyebrow">{strings.nav.blog}</p>
        <h1>{post.title[locale]}</h1>
        <p class="hero__copy">{post.description[locale]}</p>
        <p class="article-meta">
          {strings.common.updatedAt}: {post.publishedAt}
        </p>

        {post.sections.map((section) => (
          <section class="article-section">
            <h2>{section.heading[locale]}</h2>
            {section.paragraphs[locale].map((paragraph) => (
              <p set:html={paragraph} />
            ))}
            {section.bullets?.[locale] && (
              <ul class="detail-list">
                {section.bullets[locale].map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
            )}
          </section>
        ))}

        {post.relatedLinks?.length ? (
          <section class="section section--compact">
            <div class="section-heading">
              <p class="eyebrow">{strings.common.relatedPosts}</p>
              <h2>{relatedCopy.title}</h2>
              <p>{relatedCopy.description}</p>
            </div>
            <div class="card-grid">
              {post.relatedLinks.map((link) => (
                <article class="link-card">
                  <h3>{link.label[locale]}</h3>
                  <p>{link.description[locale]}</p>
                  <a class="text-link" href={link.path[locale]}>
                    {strings.common.readMore}
                  </a>
                </article>
              ))}
            </div>
          </section>
        ) : null}

        <a class="text-link" href={getBlogIndexPath(locale)}>
          {strings.nav.blog}
        </a>
      </div>
    </article>
  </main>

  <Footer locale={locale} />
</BaseLayout>
